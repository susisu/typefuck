{
  "name": "@susisu/typefuck",
  "version": "0.6.0",
  "description": "A type-level Brainfuck interpreter in TypeScript",
  "repository": "https://github.com/susisu/typefuck.git",
  "author": "Susisu <susisu2413@yahoo.co.jp>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "lib",
    "src",
    "!src/**/*.{test,spec}.{ts,tsx}",
    "!src/**/__tests__"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    }
  },
  "scripts": {
    "format": "prettier --write src '*.js'",
    "format:check": "prettier --check src '*.js'",
    "lint": "eslint --fix src '*.js'",
    "lint:check": "eslint src '*.js'",
    "test": "tsc -p tsconfig.json --noEmit",
    "test:tsgo": "tsgo -p tsconfig.json --noEmit",
    "build": "tsc --build tsconfig.build.json",
    "clean": "run-s clean:tsc clean:rm",
    "clean:tsc": "tsc --build tsconfig.build.json --clean",
    "clean:rm": "rimraf lib",
    "prepublishOnly": "run-s clean format:check lint:check test build"
  },
  "peerDependencies": {
    "typescript": ">=4.1.2"
  },
  "devDependencies": {
    "@susisu/eslint-config": "^0.0.102",
    "@typescript/native-preview": "7.0.0-dev.20260522.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3"
  }
}
